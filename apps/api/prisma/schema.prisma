// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         String   @default("USER") @db.VarChar(20)
  status       String   @default("ACTIVE") @db.VarChar(20)
  companyName  String?  @map("company_name") @db.VarChar(255)
  phone        String?  @db.VarChar(20)
  kycStatus    String   @default("PENDING") @map("kyc_status") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  campaigns        Campaign[]
  orders           Order[]
  refundRequests   RefundRequest[] @relation("UserRefundRequests")
  processedRefunds RefundRequest[] @relation("AdminProcessedRefunds")

  @@map("USERS")
}

model Campaign {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  creatorId        String   @map("creator_id") @db.Uuid
  title            String   @db.VarChar(255)
  description      String?  @db.Text
  bannerUrl        String?  @map("banner_url") @db.VarChar(512)
  avatarUrl        String?  @map("avatar_url") @db.VarChar(512)
  eventType        String   @map("event_type") @db.VarChar(50)
  city             String   @db.VarChar(100)
  location         String   @db.VarChar(255)
  startTime        DateTime @map("start_time") @db.Timestamp(6)
  endTime          DateTime @map("end_time") @db.Timestamp(6)
  status           String   @default("DRAFT") @db.VarChar(20)
  maxSeatsPerOrder Int      @default(4) @map("max_seats_per_order")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  creator            User                @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  ticketSaleSessions TicketSaleSession[]
  seats              Seat[]
  orders             Order[]

  @@map("CAMPAIGNS")
}

model TicketSaleSession {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  name       String   @db.VarChar(100)
  startTime  DateTime @map("start_time") @db.Timestamp(6)
  endTime    DateTime @map("end_time") @db.Timestamp(6)
  status     String   @default("DRAFT") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  tickets  Ticket[]
  orders   Order[]

  @@map("TICKET_SALE_SESSIONS")
}

model Seat {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String   @map("campaign_id") @db.Uuid
  areaName   String   @map("area_name") @db.VarChar(100)
  rowName    String   @map("row_name") @db.VarChar(10)
  colName    String   @map("col_name") @db.VarChar(10)
  status     String   @default("AVAILABLE") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  campaign Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  drawSeat DrawSeat?
  tickets  Ticket[]

  @@unique([campaignId, rowName, colName])
  @@map("SEATS")
}

model DrawSeat {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seatId    String   @unique @map("seat_id") @db.Uuid
  xCoord    Int      @map("x_coord")
  yCoord    Int      @map("y_coord")
  color     String?  @db.VarChar(20)
  label     String?  @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  seat Seat @relation(fields: [seatId], references: [id], onDelete: Cascade)

  @@map("DRAW_SEATS")
}

model Ticket {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId  String   @map("session_id") @db.Uuid
  seatId     String   @map("seat_id") @db.Uuid
  orderId    String?  @map("order_id") @db.Uuid
  price      Decimal  @db.Decimal(12, 2)
  ticketCode String?  @unique @map("ticket_code") @db.VarChar(100)
  status     String   @default("AVAILABLE") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  session TicketSaleSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  seat    Seat              @relation(fields: [seatId], references: [id], onDelete: Cascade)
  order   Order?            @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@unique([sessionId, seatId])
  @@map("TICKETS")
}

model Order {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerId                 String    @map("buyer_id") @db.Uuid
  campaignId              String    @map("campaign_id") @db.Uuid
  sessionId               String    @map("session_id") @db.Uuid
  totalPrice              Decimal   @map("total_price") @db.Decimal(12, 2)
  status                  String    @default("PENDING") @db.VarChar(20)
  paymentGateway          String?   @map("payment_gateway") @db.VarChar(50)
  idempotencyKey          String    @unique @map("idempotency_key") @db.VarChar(255)
  virtualAccountNumber    String?   @map("virtual_account_number") @db.VarChar(100)
  virtualAccountExpiresAt DateTime? @map("virtual_account_expires_at") @db.Timestamp(6)
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt               DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  buyer               User                 @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  campaign            Campaign             @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  session             TicketSaleSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tickets             Ticket[]
  paymentTransactions PaymentTransaction[]
  refundRequest       RefundRequest?

  @@map("ORDERS")
}

model PaymentTransaction {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId              String   @map("order_id") @db.Uuid
  transactionReference String   @map("transaction_reference") @db.VarChar(255)
  amount               Decimal  @db.Decimal(12, 2)
  status               String   @db.VarChar(50)
  callbackPayload      Json?    @map("callback_payload")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("PAYMENT_TRANSACTIONS")
}

model RefundRequest {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId     String   @unique @map("order_id") @db.Uuid
  buyerId     String   @map("buyer_id") @db.Uuid
  amount      Decimal  @db.Decimal(12, 2)
  reason      String   @db.Text
  status      String   @db.VarChar(20)
  processedBy String?  @map("processed_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  buyer     User  @relation("UserRefundRequests", fields: [buyerId], references: [id], onDelete: Cascade)
  processor User? @relation("AdminProcessedRefunds", fields: [processedBy], references: [id], onDelete: SetNull)

  @@map("REFUND_REQUESTS")
}

model SystemConfig {
  configKey   String   @id @map("config_key") @db.VarChar(255)
  configValue String   @map("config_value") @db.Text
  description String?  @db.Text
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("SYSTEM_CONFIGS")
}
