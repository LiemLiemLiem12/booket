# ==========================================
# DATABASE CONFIGURATION (POSTGRESQL)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=booket
POSTGRES_PORT=5432

# Connection string for Prisma / TypeORM
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/booket?schema=public

# ==========================================
# CACHE & LOCK CONFIGURATION (REDIS)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
